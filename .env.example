# ===========================================
# Christex Attend - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# -------------------------------------------
# Database (Required)
# -------------------------------------------
# PostgreSQL connection string. Neon serverless recommended.
# Get one free at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -------------------------------------------
# Authentication (Required)
# -------------------------------------------
# Secret key used to sign JWT tokens for admin authentication.
# Generate one with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# -------------------------------------------
# App URL (Optional)
# -------------------------------------------
# Base URL used for OpenGraph/social preview images.
# Defaults to the request origin if not set.
# Set this to your production domain in deployment.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
